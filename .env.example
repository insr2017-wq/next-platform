# PostgreSQL (obrigatório) — local (Docker), Supabase, Neon, etc.
# Exemplo Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Conta admin (npm run db:seed): login em /login → /admin/dashboard
# ADMIN_SEED_PHONE="11999999999"
# ADMIN_SEED_PASSWORD="admin123"

# JWT secret for session tokens (use a long random string in production)
JWT_SECRET="your-secret-key-change-in-production"

# URL pública da aplicação (callbacks Pix / links absolutos)
# NEXT_PUBLIC_APP_URL="https://seu-dominio.com"
# APP_URL="https://seu-dominio.com"

# VizzionPay — Pix receber (somente servidor; nunca commitar chaves reais)
# Opcional: sobrescreve a URL do endpoint (padrão: app.vizzionpay.com.br/.../pix/receive)
# Não use app.vizzionpay.com sem .br — redirects 301 fazem o fetch trocar POST por GET e a API retorna 405.
# VIZZIONPAY_PIX_RECEIVE_URL="https://app.vizzionpay.com.br/api/v1/gateway/pix/receive"
# VIZZIONPAY_PUBLIC_KEY=""
# VIZZIONPAY_SECRET_KEY=""
# ID do produto de "recarga" criado no painel VizzionPay (ativo / à venda). Obrigatório para gerar Pix.
# VIZZIONPAY_DEPOSIT_PRODUCT_ID=""
# Se o produto no painel tem preço unitário fixo (ex.: R$ 1,00), defina para enviar quantity = valor/unit:
# VIZZIONPAY_DEPOSIT_PRODUCT_UNIT_PRICE="1"
# Se o gateway rejeitar o campo price na linha, tente omitir (usa principalmente `amount` na raiz):
# VIZZIONPAY_DEPOSIT_PRODUCT_OMIT_PRICE="true"
# Domínio opcional para e-mail sintético do pagador (evita host localhost se a URL pública não estiver definida)
# VIZZIONPAY_CLIENT_EMAIL_DOMAIN="seudominio.com.br"
# URL opcional para consulta manual de status do Pix (botão "Já paguei"): {identifier}, {gatewayTransactionId}, {gatewayOrderId}, {gatewayRef} (tx ou order)
# VIZZIONPAY_PIX_QUERY_URL="https://app.vizzionpay.com.br/api/v1/gateway/pix/receive/status?identifier={identifier}"
